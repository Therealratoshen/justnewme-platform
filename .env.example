# --- JustNewMe ---

# Server
NODE_ENV=development
PORT=3456

# --- Auth (production) ---
# Use a JWT secret for signed session cookies
AUTH_SECRET=dev-secret-change-me-32-chars-min

# --- Stripe (test mode keys) ---
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Connect: platform's webhook secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Platform fee in basis points (1500 = 15%)
JUSTNEWME_PLATFORM_FEE_BPS=1500

# --- Data store ---
# In-memory for dev. Swap for Supabase/Postgres in prod.
DATA_BACKEND=memory
